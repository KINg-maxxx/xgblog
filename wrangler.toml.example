# 评论功能的一次性开通配置。
# 步骤见 docs/comments-setup.md。完成后把本文件重命名为 wrangler.toml。

name = "xgblog"
pages_build_output_dir = "dist"
compatibility_date = "2026-01-01"

# 评论数据存储（Cloudflare KV）
# 运行 `npx wrangler kv namespace create COMMENTS` 后，把输出的 id 填到下面
[[kv_namespaces]]
binding = "COMMENTS"
id = "把这里替换成 KV namespace 的 id"
